# Egress-hardened variant of the upstream ollama image: adds the iptables/
# ipset tooling and firewall scripts needed to run a deny-by-default egress
# allowlist inside this service's OWN network namespace (see
# ollama-init-firewall.sh for the rules and rationale). Shared by both the
# `ollama` and `ollama-gpu` services in docker-compose.yml.
ARG OLLAMA_VERSION=0.31.1
FROM ollama/ollama:${OLLAMA_VERSION}

# Install at BUILD time (open network here) so the locked-down runtime
# firewall this same image sets up at container start never needs to fetch
# anything itself.
RUN apt-get update && apt-get install -y --no-install-recommends \
  iptables \
  ipset \
  iproute2 \
  dnsutils \
  curl \
  ca-certificates \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

# claude-241: setpriv-drop-args.sh is the single source of truth for the
# SETPRIV_DROP array -- COPY'd here, before the guard below, so the guard can
# source the SAME file ollama-entrypoint.sh sources at runtime instead of a
# separately hand-typed (and driftable) copy of the same args.
COPY setpriv-drop-args.sh /usr/local/bin/setpriv-drop-args.sh

# setpriv (util-linux) drops NET_ADMIN/NET_RAW before ollama serve starts
# (see ollama-entrypoint.sh, which sources setpriv-drop-args.sh above) --
# util-linux is Essential on Debian/Ubuntu so it should already be present;
# fail the BUILD loudly here instead of discovering it's missing at container
# start. Beyond just existing, setpriv must also ACCEPT the drop args in that
# shared file -- a prior regression used cap_-prefixed names (e.g.
# cap_net_admin) that setpriv rejects; only the UN-prefixed form
# (net_admin/net_raw) is valid. This sources setpriv-drop-args.sh itself (the
# exact file ollama-entrypoint.sh sources at runtime -- not a re-typed copy
# that could diverge from it) and runs the real invocation against it with a
# harmless `true` payload, proving existence, sourceability, AND
# argument-acceptance for the ACTUAL runtime args in one shot: dropping an
# already-absent capability still exits 0 (works regardless of this build
# container's own cap set), so only a rejected cap NAME/flag -- or a failure
# to source the file at all -- fails the build here, exactly the classes of
# error that would otherwise slip through to a runtime failure. `set -euo
# pipefail` is required for that guarantee: without it, a failed `.` source
# (missing file, bad COPY, permissions, a syntax error introduced into
# setpriv-drop-args.sh) would NOT abort the script, and the command actually
# run would silently degrade to a bare `setpriv true` -- which trivially
# succeeds and reports "passed" with the guard never having actually checked
# anything. NOTE: `set -u` alone does NOT close this gap the way it looks like
# it should -- verified locally with bash 5.2/setpriv 2.38.1 (matching this
# image's util-linux): `"${SETPRIV_DROP[@]}"` on a totally-unset array is
# exempt from nounset in bash, the same carve-out `$@` gets (an unset SCALAR
# does trip -u; an unset ARRAY referenced via [@]/[*] does not) -- so a source
# that succeeds but never actually declares SETPRIV_DROP (e.g. a wrong var
# name, or a truncated-but-syntactically-valid file) would still silently
# expand to zero words even under `-u`. The explicit `-eq 0` count check below
# is what actually enforces "SETPRIV_DROP must be non-empty after sourcing";
# `-eu` guards the other failure modes (missing file, bad source, non-zero
# exit from setpriv itself). A correctly-populated array still expands fine
# under `-u` (this is only an issue for genuinely unset/empty arrays). Uses
# `bash -c` explicitly (not the default `/bin/sh`) because SETPRIV_DROP is a
# bash array -- bash is already a hard runtime dependency of this image via
# ollama-entrypoint.sh's own `#!/bin/bash` shebang, so this adds no new tool.
RUN bash -c ' \
    set -euo pipefail; \
    . /usr/local/bin/setpriv-drop-args.sh; \
    if [ "${#SETPRIV_DROP[@]}" -eq 0 ]; then \
      echo "ERROR: setpriv-drop-args.sh sourced cleanly but left SETPRIV_DROP empty/undeclared -- check the file was COPYd correctly and still assigns the array" >&2; \
      exit 1; \
    fi; \
    if ! setpriv "${SETPRIV_DROP[@]}" true; then \
      echo "ERROR: setpriv rejected the cap-drop args in setpriv-drop-args.sh (${SETPRIV_DROP[*]}) that ollama-entrypoint.sh depends on at runtime; check setpriv is installed from util-linux and its cap names are un-prefixed (net_admin/net_raw, not cap_net_admin/cap_net_raw)" >&2; \
      exit 1; \
    fi'

COPY firewall-common.sh /usr/local/bin/firewall-common.sh
COPY ollama-init-firewall.sh /usr/local/bin/ollama-init-firewall.sh
COPY ollama-entrypoint.sh /usr/local/bin/ollama-entrypoint.sh
RUN chmod +x /usr/local/bin/firewall-common.sh /usr/local/bin/ollama-init-firewall.sh /usr/local/bin/ollama-entrypoint.sh

# claude-qje (Round 2, belt-and-suspenders for the REBORN_MARKER check --
# see ollama-entrypoint.sh, which explains what that mechanism does and does
# NOT defend against): ollama-entrypoint.sh treats
# /run/ollama-entrypoint-reborn existing as proof it already took the
# legitimate setpriv re-exec that drops NET_ADMIN/NET_RAW, and uses its
# ABSENCE to detect a container that started with those caps already missing
# (cap_add misconfigured) rather than legitimately dropped. If this exact
# path were ever baked into this image's own build -- e.g. a future `RUN
# touch`/COPY landing something at /run/ollama-entrypoint-reborn -- every
# container from that image would start pre-forged into the "legitimately
# reborn" state and silently skip the firewall with cap_add still missing.
# /run is tmpfs and always empty at this point in a stock upstream layer, so
# this should never actually trip; it exists to turn an accidental future
# regression in THIS Dockerfile into a build failure instead of a silent
# runtime hole. It can NOT catch a fork of this Dockerfile that removes or
# reorders this very check, or a `docker commit`/out-of-band bind mount done
# outside this build entirely -- see ollama-entrypoint.sh for why that tier
# of access is out of scope for a runtime file check by construction.
RUN bash -c ' \
    set -euo pipefail; \
    if [ -e /run/ollama-entrypoint-reborn ]; then \
      echo "ERROR: /run/ollama-entrypoint-reborn already exists in this built image layer -- ollama-entrypoint.sh relies on this path being ABSENT until it writes it at runtime, right before its legitimate setpriv re-exec; baking it into the image would let a container start pre-forged into that state with cap_add still missing, silently skipping the egress firewall. Find and remove whatever RUN/COPY step created this path." >&2; \
      exit 1; \
    fi'

# claude-r30.2: fallback default, only in effect if this image is ever run
# directly without docker-compose.yml (e.g. `docker run`). The normal
# override point is docker-compose.yml's `OLLAMA_MODEL: ${OLLAMA_MODEL:-...}`
# interpolation (a compose `environment:` entry always wins over this ENV at
# runtime) -- keep this literal in sync with that default if it ever changes.
# See tools/ollama-mcp/README.md's Model section for the size/accuracy/speed
# tradeoff behind the choice.
ENV OLLAMA_MODEL=llama3.2:3b

# Upstream image already runs as root (no non-root user defined), and
# iptables/ipset need root + NET_ADMIN/NET_RAW (granted via cap_add in
# docker-compose.yml) to program the firewall regardless -- so this doesn't
# change the *build-time* privilege baseline. It DOES change the runtime
# posture, though: right after the firewall is applied, ollama-entrypoint.sh
# re-execs ITSELF (not just the eventual `ollama serve` process) through
# setpriv to drop NET_ADMIN/NET_RAW -- so nothing that runs from that point
# on in this container (the entrypoint's own warm/pull supervisor logic,
# `ollama serve`, or anything either forks) ever holds the capabilities that
# could undo its own firewall. See ollama-entrypoint.sh for why a plain
# per-child setpriv wrap wouldn't have been enough on its own.

# claude-r30.2: reports healthy only once BOTH the server is answering AND
# $OLLAMA_MODEL has been pulled and is present locally -- see
# ollama-entrypoint.sh's WARM section, which is what actually pulls it before
# this can ever pass -- so "healthy" genuinely means "ready to serve
# $OLLAMA_MODEL", not just "process is up" (visible via `docker compose ps`/
# `docker inspect --format='{{.State.Health.Status}}'`). No compose service
# currently declares `depends_on: ollama: condition: service_healthy` on
# this one (deliberately -- see docker-compose.yml's `devcontainer` service:
# gating its startup on this would block every `docker compose up` on a
# first, from-cold multi-GB pull, even for uses that never touch
# ollama-mcp). In practice the cold-start race this exists to avoid is still
# closed because ollama-mcp is spawned per-Claude-session, well after this
# container is already up -- not because anything in compose blocks on this
# HEALTHCHECK today. `ollama list`'s first column is an exact model:tag;
# grep it anchored and whitespace-terminated so e.g. llama3.2:3b doesn't
# false-match llama3.2:3b-instruct-q8_0 (the unescaped "." in a pulled-in
# $OLLAMA_MODEL could in theory match any single character instead of a
# literal dot here -- an acceptable imprecision for a healthcheck, not a
# security boundary). start-period=1800s (30 min) covers a first, from-cold
# multi-GB pull over the proxied egress path without counting those retries
# against --retries; once the model is cached in the ollama-models volume,
# restarts pass on the first check.
HEALTHCHECK --interval=10s --timeout=5s --start-period=1800s --retries=3 \
  CMD ollama list 2>/dev/null | grep -Eq "^${OLLAMA_MODEL:-llama3.2:3b}[[:space:]]" || exit 1

ENTRYPOINT ["/usr/local/bin/ollama-entrypoint.sh"]
CMD ["serve"]
