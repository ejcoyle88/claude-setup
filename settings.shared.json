{
  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Read(~/.claude/.credentials.json)",
      "Edit(~/.claude/.credentials.json)",
      "Read(~/.claude/.claude.json)",
      "Edit(~/.claude/.claude.json)",
      "Bash(jq * ~/.ssh/*)",
      "Bash(jq * ~/.aws/*)",
      "Bash(jq *.env*)",
      "Bash(jq * ~/.claude/.credentials.json*)",
      "Bash(jq * ~/.claude/.claude.json*)"
    ],
    "allow": [
      "Bash(.specify/scripts/bash/setup-plan.sh:*)",
      "Bash(git checkout:*)",
      "Bash(.specify/scripts/bash/update-agent-context.sh:*)",
      "Bash(.specify/scripts/bash/check-prerequisites.sh:*)",
      "Bash(test:*)",
      "Bash(git rev-parse:*)",
      "Bash(dotnet new:*)",
      "Bash(dotnet sln:*)",
      "Bash(ls:*)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(do test:*)",
      "Bash(echo:*)",
      "Bash(done)",
      "Bash(dotnet list:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(.specify/scripts/bash/create-new-feature.sh:*)",
      "WebSearch",
      "Bash(bash:*)",
      "Bash(fi)",
      "Bash(dotnet tool install:*)",
      "Bash(dotnet tool restore:*)",
      "Bash(dotnet fantomas:*)",
      "Bash(dotnet fsharplint:*)",
      "Bash(chmod:*)",
      "Bash(git config:*)",
      "mcp__serena__initial_instructions",
      "mcp__serena__get_symbols_overview",
      "mcp__ollama-mcp__ping",
      "mcp__ollama-mcp__health",
      "mcp__ollama-mcp__summarize_file",
      "mcp__ollama-mcp__extract",
      "mcp__ollama-mcp__classify"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/lsp-first-guard.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/lsp-first-guard.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "product-management@knowledge-work-plugins": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "knowledge-work-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/knowledge-work-plugins"
      }
    }
  },
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "tui": "fullscreen",
  "env": {
    "ENABLE_LSP_TOOL": "1"
  }
}
